# GEMINI_API_KEY: Required for multi-agent stencil analysis.
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_API_KEY_HERE"

# APP_URL: Injected automatically in production.
# Used for internal routing and API callbacks.
APP_URL="http://localhost:3000"

# STENCIL_PRECISION: Default node reduction factor (0.1 - 1.0)
VITE_STENCIL_PRECISION="0.8"
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
